APP_PASSWORD=           # Login password
APP_SECRET=             # HMAC key for session cookies (generate with: openssl rand -hex 32)
TOTP_SECRET=            # Base32 TOTP secret (set after /setup-2fa)
SPOTIFY_CLIENT_ID=      # From developer.spotify.com
SPOTIFY_CLIENT_SECRET=  # From developer.spotify.com
SPOTIFY_REDIRECT_URI=https://bridge.invalid/callback  # Doesn't need to be a real URL
TURSO_URL=              # libsql://your-db.turso.io
TURSO_AUTH_TOKEN=       # Turso auth token
LASTFM_API_KEY=         # From last.fm/api/account/create
